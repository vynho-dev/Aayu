{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/aayu-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='AssessmentCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|children|key|ref|className|style|children)$/]",
        "message": "<AssessmentCard> doesn't accept that prop. Declared props: icon, title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='BottomSheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|onClose|primaryLabel|onPrimary|key|ref|className|style|children)$/]",
        "message": "<BottomSheet> doesn't accept that prop. Declared props: title, children, onClose, primaryLabel, onPrimary."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|loading|disabled|children|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, loading, disabled, children, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md)$/]",
        "message": "<Button> size must be one of 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|error|value|onChange|type|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, placeholder, error, value, onChange, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='LetterCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|preview|editable|onDownload|key|ref|className|style|children)$/]",
        "message": "<LetterCard> doesn't accept that prop. Declared props: title, preview, editable, onDownload."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|subtitle|onClick|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: icon, title, subtitle, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|tone|key|ref|className|style|children)$/]",
        "message": "<MetricCard> doesn't accept that prop. Declared props: label, value, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ink|teal)$/]",
        "message": "<MetricCard> tone must be one of 'ink' | 'teal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PatientSelector'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|relation|age|selected|onClick|key|ref|className|style|children)$/]",
        "message": "<PatientSelector> doesn't accept that prop. Declared props: name, relation, age, selected, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<StatusChip> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|attention|neutral)$/]",
        "message": "<StatusChip> tone must be one of 'success' | 'attention' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrustBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|children|key|ref|className|style|children)$/]",
        "message": "<TrustBadge> doesn't accept that prop. Declared props: icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='UploadFile'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|status|key|ref|className|style|children)$/]",
        "message": "<UploadFile> doesn't accept that prop. Declared props: name, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='UploadFile'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:reading|done|unreadable)$/]",
        "message": "<UploadFile> status must be one of 'reading' | 'done' | 'unreadable'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "AssessmentCard": {
        "replaces": []
